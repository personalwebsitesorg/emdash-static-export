---
export const prerender = false;

// ── Auth check: must be logged in with admin role ──
const user = (Astro.locals as any).user;
if (!user) {
	return Astro.redirect("/_emdash/admin");
}
if (user.role < 50) {
	return new Response(`Forbidden: admin role required. Current role: ${JSON.stringify(user.role)}`, { status: 403 });
}

// security headers
Astro.response.headers.set("X-Frame-Options", "DENY");
Astro.response.headers.set("X-Content-Type-Options", "nosniff");
Astro.response.headers.set("Cache-Control", "no-store, no-cache, must-revalidate");

// ── CSRF check: POST must include valid origin ──
if (Astro.request.method === "POST") {
	const expectedOrigin = Astro.url.origin;
	const origin = Astro.request.headers.get("Origin");
	const referer = Astro.request.headers.get("Referer");
	let sourceOrigin: string | null = origin;

	if (!sourceOrigin && referer) {
		try {
			sourceOrigin = new URL(referer).origin;
		} catch (e) {
			// ignore invalid referer URL
		}
	}

	if (!sourceOrigin || sourceOrigin !== expectedOrigin) {
		return new Response("Forbidden: CSRF check failed", { status: 403 });
	}
}

const emdash = (Astro.locals as any).emdash;
const db = emdash?.db;
const storage = emdash?.storage;

// ── Handle POST (do the export) ──

const R2_KEY = "exports/site-export.json";
let result: { success: boolean; size?: number; error?: string } | null = null;

// Tables not needed by the frontend — filter out before uploading to R2
const REMOVE_TABLES = [
	"revisions",
	"_emdash_migrations",
	"_emdash_collections",
	"_emdash_fields",
	"_emdash_taxonomy_defs",
	"_emdash_sections",
];

if (Astro.request.method === "POST" && db && storage) {
	try {
		// lazily import generateSnapshot only on POST
		const { generateSnapshot } = await import("emdash-snapshot");
		const snapshot = await generateSnapshot(db, { origin: Astro.url.origin });

		// modify snapshot in-place
		// assign undefined instead of using 'delete' to avoid V8 degrading the object
		// JSON.stringify will skip those values anyway
		for (const table of REMOVE_TABLES) {
			snapshot.tables[table] = undefined;
			snapshot.schema[table] = undefined;
		}

		const json = JSON.stringify(snapshot);
		const body = new TextEncoder().encode(json);

		await storage.upload({
			key: R2_KEY,
			body: body,
			contentType: "application/json",
		});

		result = { success: true, size: body.length };
	} catch (e: any) {
		result = { success: false, error: e.message || String(e) };
	}
}
---
<html lang="en">
<head>
	<meta charset="utf-8" />
	<title>Static Export — EmDash</title>
	<style>
		* { box-sizing: border-box; margin: 0; padding: 0; }
		body {
			font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", system-ui, sans-serif;
			background: #0f1117;
			color: #e4e4e7;
			min-height: 100vh;
			display: flex;
			align-items: center;
			justify-content: center;
		}
		.card {
			background: #18181b;
			border: 1px solid #27272a;
			border-radius: 12px;
			padding: 32px;
			max-width: 480px;
			width: 100%;
		}
		h1 { font-size: 20px; font-weight: 600; margin-bottom: 8px; }
		.desc { color: #a1a1aa; font-size: 14px; margin-bottom: 24px; line-height: 1.5; }
		form { margin-bottom: 16px; }
		button {
			width: 100%;
			padding: 12px;
			font-size: 15px;
			font-weight: 500;
			cursor: pointer;
			background: #2563eb;
			color: white;
			border: none;
			border-radius: 8px;
			transition: background 0.15s;
		}
		button:hover { background: #1d4ed8; }
		button:active { background: #1e40af; }
		.result {
			padding: 14px;
			border-radius: 8px;
			font-size: 14px;
			margin-bottom: 16px;
			line-height: 1.5;
		}
		.success { background: #052e16; border: 1px solid #166534; color: #86efac; }
		.error { background: #450a0a; border: 1px solid #991b1b; color: #fca5a5; }
		.meta { color: #71717a; font-size: 13px; margin-top: 16px; }
		.meta a { color: #60a5fa; text-decoration: none; }
		.meta a:hover { text-decoration: underline; }
		.key { font-family: monospace; font-size: 12px; color: #a1a1aa; background: #27272a; padding: 2px 6px; border-radius: 4px; }
		.go-deploy {
			display: block;
			width: 100%;
			padding: 12px;
			margin-bottom: 16px;
			background: #16a34a;
			color: white;
			border: none;
			border-radius: 8px;
			font-size: 15px;
			font-weight: 500;
			text-align: center;
			text-decoration: none;
			transition: background 0.15s;
		}
		.go-deploy:hover { background: #15803d; }
	</style>
</head>
<body>
	<div class="card">
		<h1>Static Export</h1>
		<p class="desc">
			Export the full site snapshot to R2. Includes all published posts, pages,
			media, menus, settings, taxonomies, SEO, and bylines.
		</p>

		{result?.success && (
			<>
				<div class="result success">
					Exported to R2 — <strong>{(result.size! / 1024).toFixed(1)} KB</strong>
					<br />Key: <span class="key">{R2_KEY}</span>
				</div>
				<a class="go-deploy" href="/_emdash/admin/plugins/deploy-hook/themes">
					Go to Deploy →
				</a>
			</>
		)}

		{result && !result.success && (
			<div class="result error">
				Export failed: {result.error}
			</div>
		)}

		{!db && (
			<div class="result error">EmDash not initialized</div>
		)}

		{!storage && db && (
			<div class="result error">R2 storage not configured</div>
		)}

		{db && storage && (
			<form method="POST">
				<button type="submit">Export to R2</button>
			</form>
		)}

		<div class="meta">
			<a href="/_emdash/admin/plugins/deploy-hook/themes">← Back to Themes & Deploy</a>
		</div>
	</div>
</body>
</html>
