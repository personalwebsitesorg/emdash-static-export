---
export const prerender = false;

import { sql } from "kysely";

// ── Auth check: must be logged in with admin role ──
const user = (Astro.locals as any).user;
if (!user) {
	return Astro.redirect("/_emdash/admin");
}
if (user.role < 50) {
	return new Response("Forbidden: admin role required", { status: 403 });
}

// ── CSRF check: POST must include X-EmDash-Request header or valid origin ──
if (Astro.request.method === "POST") {
	const origin = Astro.request.headers.get("Origin");
	const expectedOrigin = Astro.url.origin;
	if (origin && origin !== expectedOrigin) {
		return new Response("Forbidden: CSRF check failed", { status: 403 });
	}
}

const emdash = (Astro.locals as any).emdash;
const db = emdash?.db;
const storage = emdash?.storage;

// ── Snapshot logic (from emdash core) ──

const SAFE_TABLE_NAME = /^[a-z_][a-z0-9_]*$/;

const SYSTEM_TABLES = [
	"_emdash_collections", "_emdash_fields", "_emdash_taxonomy_defs",
	"_emdash_menus", "_emdash_menu_items", "_emdash_sections",
	"_emdash_widget_areas", "_emdash_widgets", "_emdash_seo",
	"_emdash_migrations", "_emdash_bylines", "_emdash_content_bylines",
	"taxonomies", "content_taxonomies", "media", "options", "revisions",
];

const EXCLUDED_PREFIXES = [
	"_emdash_api_tokens", "_emdash_oauth_tokens", "_emdash_authorization_codes",
	"_emdash_device_codes", "_emdash_migrations_lock", "_plugin_",
	"users", "sessions", "credentials", "challenges",
];

const SAFE_OPTIONS_PREFIXES = ["site:"];

function isExcluded(name: string) {
	return EXCLUDED_PREFIXES.some((p) => name.startsWith(p));
}

function injectSrc(obj: any, origin: string): boolean {
	let modified = false;
	if ((obj.provider === "local" || (!obj.provider && obj.id && obj.meta)) && !obj.src) {
		const key = obj.meta?.storageKey ?? obj.id;
		if (typeof key === "string" && key) {
			obj.src = `${origin}/_emdash/api/media/file/${key}`;
			modified = true;
		}
	}
	for (const value of Object.values(obj)) {
		if (Array.isArray(value)) {
			for (const item of value as any[]) {
				if (typeof item === "object" && item && !Array.isArray(item)) {
					if (injectSrc(item, origin)) modified = true;
				}
			}
		} else if (typeof value === "object" && value && !Array.isArray(value)) {
			if (injectSrc(value as any, origin)) modified = true;
		}
	}
	return modified;
}

async function generateSnapshot(db: any, origin: string) {
	const tableResult = await sql`
		SELECT name FROM sqlite_master WHERE type = 'table' AND name LIKE 'ec_%' ORDER BY name
	`.execute(db);

	const contentTables = (tableResult.rows as any[]).map((r: any) => r.name);
	const allTables = [...contentTables, ...SYSTEM_TABLES];
	const tables: Record<string, any[]> = {};
	const schema: Record<string, any> = {};

	for (const tableName of allTables) {
		if (isExcluded(tableName) || !SAFE_TABLE_NAME.test(tableName)) continue;

		try {
			const pragma = await sql`PRAGMA table_info(${sql.raw(`"${tableName}"`)})`.execute(db);
			const cols = pragma.rows as any[];
			if (cols.length === 0) continue;

			schema[tableName] = {
				columns: cols.map((r: any) => r.name),
				types: Object.fromEntries(cols.map((r: any) => [r.name, r.type || "TEXT"])),
			};

			let rows: any[];
			if (tableName.startsWith("ec_")) {
				rows = (await sql`
					SELECT * FROM ${sql.raw(`"${tableName}"`)}
					WHERE deleted_at IS NULL
					AND (status = 'published' OR (status = 'scheduled' AND scheduled_at <= datetime('now')))
				`.execute(db)).rows as any[];
			} else if (tableName === "options") {
				rows = ((await sql`SELECT * FROM ${sql.raw(`"${tableName}"`)}`.execute(db)).rows as any[])
					.filter((r: any) => SAFE_OPTIONS_PREFIXES.some((p) => (r.name || "").startsWith(p)));
			} else {
				rows = (await sql`SELECT * FROM ${sql.raw(`"${tableName}"`)}`.execute(db)).rows as any[];
			}

			if (rows.length > 0) tables[tableName] = rows;
		} catch { /* table may not exist */ }
	}

	// Inject media URLs
	for (const [tName, tRows] of Object.entries(tables)) {
		if (!tName.startsWith("ec_")) continue;
		for (const row of tRows) {
			for (const [col, val] of Object.entries(row)) {
				if (typeof val !== "string" || !val.startsWith("{")) continue;
				try {
					const obj = JSON.parse(val);
					if (typeof obj === "object" && obj && !Array.isArray(obj) && injectSrc(obj, origin)) {
						row[col] = JSON.stringify(obj);
					}
				} catch {}
			}
		}
	}

	return { tables, schema, generatedAt: new Date().toISOString() };
}

// ── Handle POST (do the export) ──

const R2_KEY = "exports/site-export.json";
let result: { success: boolean; size?: number; error?: string } | null = null;

if (Astro.request.method === "POST" && db && storage) {
	try {
		const snapshot = await generateSnapshot(db, Astro.url.origin);
		const json = JSON.stringify(snapshot);
		const body = new TextEncoder().encode(json);

		await storage.upload({
			key: R2_KEY,
			body: body,
			contentType: "application/json",
		});

		result = { success: true, size: body.length };
	} catch (e: any) {
		result = { success: false, error: e.message || String(e) };
	}
}
---
<html lang="en">
<head>
	<meta charset="utf-8" />
	<title>Static Export — EmDash</title>
	<style>
		* { box-sizing: border-box; margin: 0; padding: 0; }
		body {
			font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", system-ui, sans-serif;
			background: #0f1117;
			color: #e4e4e7;
			min-height: 100vh;
			display: flex;
			align-items: center;
			justify-content: center;
		}
		.card {
			background: #18181b;
			border: 1px solid #27272a;
			border-radius: 12px;
			padding: 32px;
			max-width: 480px;
			width: 100%;
		}
		h1 { font-size: 20px; font-weight: 600; margin-bottom: 8px; }
		.desc { color: #a1a1aa; font-size: 14px; margin-bottom: 24px; line-height: 1.5; }
		form { margin-bottom: 16px; }
		button {
			width: 100%;
			padding: 12px;
			font-size: 15px;
			font-weight: 500;
			cursor: pointer;
			background: #2563eb;
			color: white;
			border: none;
			border-radius: 8px;
			transition: background 0.15s;
		}
		button:hover { background: #1d4ed8; }
		button:active { background: #1e40af; }
		.result {
			padding: 14px;
			border-radius: 8px;
			font-size: 14px;
			margin-bottom: 16px;
			line-height: 1.5;
		}
		.success { background: #052e16; border: 1px solid #166534; color: #86efac; }
		.error { background: #450a0a; border: 1px solid #991b1b; color: #fca5a5; }
		.meta { color: #71717a; font-size: 13px; margin-top: 16px; }
		.meta a { color: #60a5fa; text-decoration: none; }
		.meta a:hover { text-decoration: underline; }
		.key { font-family: monospace; font-size: 12px; color: #a1a1aa; background: #27272a; padding: 2px 6px; border-radius: 4px; }
	</style>
</head>
<body>
	<div class="card">
		<h1>Static Export</h1>
		<p class="desc">
			Export the full site snapshot to R2. Includes all published posts, pages,
			media, menus, settings, taxonomies, SEO, and bylines.
		</p>

		{result?.success && (
			<div class="result success">
				Exported to R2 — <strong>{(result.size! / 1024).toFixed(1)} KB</strong>
				<br />Key: <span class="key">{R2_KEY}</span>
			</div>
		)}

		{result && !result.success && (
			<div class="result error">
				Export failed: {result.error}
			</div>
		)}

		{!db && (
			<div class="result error">EmDash not initialized</div>
		)}

		{!storage && db && (
			<div class="result error">R2 storage not configured</div>
		)}

		{db && storage && (
			<form method="POST">
				<button type="submit">Export to R2</button>
			</form>
		)}

		<div class="meta">
			<a href="/_emdash/admin">← Back to admin</a>
		</div>
	</div>
</body>
</html>
